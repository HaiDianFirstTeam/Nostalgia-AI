<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">

    <PreferenceCategory android:title="外观">
        <ListPreference
            android:key="theme_mode"
            android:title="深浅色模式"
            android:entries="@array/theme_entries"
            android:entryValues="@array/theme_values"
            android:defaultValue="system" />
    </PreferenceCategory>

    <PreferenceCategory android:title="模型与联网搜索">
        <Preference
            android:key="providers"
            android:title="模型来源 / API Key / 模型" />
        <Preference
            android:key="model_groups"
            android:title="模型组（对话页只显示组名）" />
        <Preference
            android:key="tavily"
            android:title="Tavily 联网搜索" />
    </PreferenceCategory>

    <PreferenceCategory android:title="数据">
        <Preference
            android:key="import_export"
            android:title="导入 / 导出（JSON）" />
    </PreferenceCategory>

</PreferenceScreen>
