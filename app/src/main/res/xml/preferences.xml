<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">

    <PreferenceCategory android:title="外观">
        <ListPreference
            android:key="theme_mode"
            android:title="深浅色模式"
            android:entries="@array/theme_entries"
            android:entryValues="@array/theme_values"
            android:defaultValue="system" />
    </PreferenceCategory>

    <PreferenceCategory android:title="模型与联网搜索">
        <Preference
            android:key="providers"
            android:title="模型" />
        <Preference
            android:key="tavily"
            android:title="Tavily 联网搜索" />
    </PreferenceCategory>

    <PreferenceCategory android:title="输出">
        <ListPreference
            android:key="stream_mode"
            android:title="流式输出"
            android:entries="@array/stream_mode_entries"
            android:entryValues="@array/stream_mode_values"
            android:defaultValue="on" />

        <EditTextPreference
            android:key="stream_compat_interval_ms"
            android:title="兼容流式刷新间隔(ms)"
            android:summary="兼容流式下每隔 N 毫秒刷新一次，减少老设备卡死"
            android:defaultValue="500" />
    </PreferenceCategory>

    <PreferenceCategory android:title="数据">
        <Preference
            android:key="import_export"
            android:title="导入 / 导出（JSON）" />
    </PreferenceCategory>

</PreferenceScreen>
