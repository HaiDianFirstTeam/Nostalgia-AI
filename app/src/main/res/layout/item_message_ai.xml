<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:orientation="vertical"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="2dp"
		android:orientation="vertical">

		<HorizontalScrollView
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:visibility="gone"
			android:id="@+id/chipsScroll"
			android:scrollbars="none">

			<LinearLayout
				android:id="@+id/chipsContainer"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:orientation="horizontal"
				android:baselineAligned="false"
				android:paddingStart="4dp"
				android:paddingEnd="4dp" />
		</HorizontalScrollView>

		<androidx.appcompat.widget.AppCompatImageButton
			android:id="@+id/btnExpandChips"
			android:layout_width="32dp"
			android:layout_height="32dp"
			android:layout_marginTop="2dp"
			android:background="@android:color/transparent"
			android:contentDescription="展开"
			android:visibility="gone"
			app:srcCompat="@android:drawable/arrow_down_float"
			app:tint="?attr/colorControlNormal" />
	</LinearLayout>

	<TextView
		android:id="@+id/tvContent"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_marginTop="2dp"
		android:background="@drawable/bg_bubble_ai"
		android:textColor="?android:attr/textColorPrimary" />

	<LinearLayout
		android:id="@+id/branchBar"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_marginTop="4dp"
		android:orientation="horizontal"
		android:gravity="center_vertical"
		android:visibility="gone">

		<androidx.appcompat.widget.AppCompatImageButton
			android:id="@+id/btnBranchPrev"
			android:layout_width="32dp"
			android:layout_height="32dp"
			android:background="@android:color/transparent"
			android:contentDescription="上一分支"
			app:srcCompat="@android:drawable/ic_media_previous"
			app:tint="?attr/colorControlNormal" />

		<TextView
			android:id="@+id/tvBranchInfo"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:alpha="0.7"
			android:textSize="12sp"
			android:text="1/1"
			android:paddingLeft="4dp"
			android:paddingRight="4dp" />

		<androidx.appcompat.widget.AppCompatImageButton
			android:id="@+id/btnBranchNext"
			android:layout_width="32dp"
			android:layout_height="32dp"
			android:background="@android:color/transparent"
			android:contentDescription="下一分支"
			app:srcCompat="@android:drawable/ic_media_next"
			app:tint="?attr/colorControlNormal" />
	</LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnDelete"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/action_delete"
            app:srcCompat="@android:drawable/ic_menu_delete"
            app:tint="?attr/colorControlNormal" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnEdit"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/action_edit"
            app:srcCompat="@drawable/ic_edit_24"
            app:tint="?attr/colorControlNormal" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnCopy"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/action_copy"
            app:srcCompat="@drawable/ic_copy_24"
            app:tint="?attr/colorControlNormal" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnRetry"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/action_retry"
            app:srcCompat="@drawable/ic_retry_24"
            app:tint="?attr/colorControlNormal" />
    </LinearLayout>

</LinearLayout>
