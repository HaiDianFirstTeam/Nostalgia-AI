<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:title="播放器" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:padding="16dp">

        <FrameLayout
            android:id="@+id/coverContainer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_music_cover_dot"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_percent="0.62"
            app:layout_constraintDimensionRatio="1:1">

            <ImageView
                android:id="@+id/imgCover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="封面" />

            <!-- Inline lyrics mode (toggled by tapping cover) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvInlineLyrics"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:paddingTop="18dp"
                android:paddingBottom="18dp"
                android:visibility="gone" />

            <!-- Fade scrims for lyrics mode -->
            <View
                android:id="@+id/vInlineFadeTop"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:background="@drawable/bg_lyrics_fade_top"
                android:visibility="gone" />

            <View
                android:id="@+id/vInlineFadeBottom"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_lyrics_fade_bottom"
                android:visibility="gone" />

        </FrameLayout>

        <!-- Back to cover (shown only in lyrics mode) -->
        <LinearLayout
            android:id="@+id/btnBackCover"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="@+id/coverContainer"
            app:layout_constraintStart_toEndOf="@+id/coverContainer"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="10dp">

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                app:srcCompat="@android:drawable/ic_menu_revert"
                app:tint="?attr/colorControlNormal" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="返回封面"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorPrimary" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textStyle="bold"
            android:textSize="18sp"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@+id/coverContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvArtist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:alpha="0.7"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@+id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <SeekBar
            android:id="@+id/seek"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@+id/tvArtist"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:alpha="0.7"
            android:textSize="12sp"
            android:text="00:00 / 00:00"
            app:layout_constraintTop_toBottomOf="@+id/seek"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/controls"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@+id/tvTime"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintVertical_chainStyle="packed">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnMode"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:contentDescription="模式"
                app:srcCompat="@android:drawable/ic_menu_rotate"
                app:tint="?attr/colorControlNormal" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnSpeed"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="2dp"
                android:background="@android:color/transparent"
                android:contentDescription="倍速"
                app:srcCompat="@android:drawable/ic_media_ff"
                app:tint="?attr/colorControlNormal" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnPrev"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="6dp"
                android:background="@android:color/transparent"
                android:contentDescription="上一首"
                app:srcCompat="@android:drawable/ic_media_previous"
                app:tint="?attr/colorControlNormal" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnPlayPause"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="@android:color/transparent"
                android:contentDescription="播放/暂停"
                app:srcCompat="@android:drawable/ic_media_play"
                app:tint="?attr/colorControlNormal" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnNext"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="6dp"
                android:background="@android:color/transparent"
                android:contentDescription="下一首"
                app:srcCompat="@android:drawable/ic_media_next"
                app:tint="?attr/colorControlNormal" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnQueue"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:contentDescription="播放列表"
                app:srcCompat="@android:drawable/ic_menu_sort_by_size"
                app:tint="?attr/colorControlNormal" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
